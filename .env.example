# Environment Variables Template
# Copy this to .env and fill in your values

# ======================
# Database Configuration
# ======================

# Local Development (SQLite)
DATABASE_URL="file:./dev.db"

# Production (PostgreSQL - get this from Digital Ocean Database)
# DATABASE_URL="postgresql://username:password@host:port/database?sslmode=require"

# ======================
# Authentication & Security
# ======================

# JWT Secret (Generate using: openssl rand -base64 32)
JWT_SECRET="your-secret-key-min-32-characters-long"

# NextAuth Configuration
NEXTAUTH_SECRET="your-nextauth-secret-min-32-characters"
NEXTAUTH_URL="http://localhost:3000"  # Change to your production URL

# ======================
# Email Configuration (Azure/Entra)
# ======================
# See ENTRA_EMAIL_SETUP.md for setup instructions

AZURE_CLIENT_ID="your-azure-app-client-id"
AZURE_CLIENT_SECRET="your-azure-client-secret"
AZURE_TENANT_ID="your-azure-tenant-id"
EMAIL_FROM="noreply@yourdomain.com"

# ======================
# Application Settings
# ======================

NODE_ENV="development"  # "development" or "production"

# ======================
# Optional: Application URLs
# ======================

# Base URL for the application
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# API Base URL (if different from app URL)
# NEXT_PUBLIC_API_URL="http://localhost:3000/api"
