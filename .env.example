# Environment Variables Template
# Copy this to .env and fill in your values

# ======================
# Database Configuration
# ======================

# Production Database (DigitalOcean Managed PostgreSQL)
DATABASE_URL="postgresql://doadmin:<DIGITALOCEAN_DB_PASSWORD>@icgymhub-db-do-user-25561005-0.m.db.ondigitalocean.com:25060/icgymhub_production?sslmode=require"

# ======================
# Authentication & Security
# ======================

# JWT Secret (Generate using: openssl rand -base64 32)
JWT_SECRET="your-secret-key-min-32-characters-long"

# NextAuth Configuration
NEXTAUTH_SECRET="your-nextauth-secret-min-32-characters"
NEXTAUTH_URL="https://your-production-domain.com"

# Cron Job Secret (for scheduled tasks like club deletion)
# Generate using: openssl rand -base64 32
CRON_SECRET="your-cron-secret-key-min-32-characters"

# ======================
# Email Configuration (Azure/Entra)
# ======================
# See ENTRA_EMAIL_SETUP.md for setup instructions

AZURE_CLIENT_ID="your-azure-app-client-id"
AZURE_CLIENT_SECRET="your-azure-client-secret"
AZURE_TENANT_ID="your-azure-tenant-id"
EMAIL_FROM="noreply@yourdomain.com"

# ======================
# Application Settings
# ======================

NODE_ENV="production"

# ======================
# Optional: Application URLs
# ======================

# Base URL for the application
NEXT_PUBLIC_APP_URL="https://your-production-domain.com"

# API Base URL (if different from app URL)
NEXT_PUBLIC_API_URL="https://your-production-domain.com/api"
