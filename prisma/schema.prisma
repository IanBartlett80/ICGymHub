generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Club {
  id                    String               @id @default(cuid())
  name                  String               @unique
  slug                  String               @unique
  abn                   String?              @unique
  domain                String               @unique
  status                String               @default("PENDING_VERIFICATION")
  timezone              String               @default("Australia/Sydney")
  address               String?
  city                  String?
  state                 String?
  postalCode            String?
  phone                 String?
  website               String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  qrAccessPin           String?
  qrPinResetToken       String?              @unique
  qrPinResetTokenExpiry DateTime?
  qrPinUpdatedAt        DateTime?
  auditLogs             AuditLog[]
  classSessions         ClassSession[]
  classTemplates        ClassTemplate[]
  clubDomains           ClubDomain[]
  services              ClubService[]
  coaches               Coach[]
  coachImportJobs       CoachImportJob[]
  complianceCategories  ComplianceCategory[]
  complianceItems       ComplianceItem[]
  emailVerifications    EmailVerification[]
  equipment             Equipment[]
  equipmentCategories   EquipmentCategory[]
  equipmentUsage        EquipmentUsage[]
  gymsports             Gymsport[]
  injuryFormTemplates   InjuryFormTemplate[]
  injuryNotifications   InjuryNotification[]
  injurySubmissions     InjurySubmission[]
  maintenanceLogs       MaintenanceLog[]
  maintenanceTasks      MaintenanceTask[]
  repairQuoteRequests   RepairQuoteRequest[]
  rosters               Roster[]
  rosterExports         RosterExport[]
  rosterSlots           RosterSlot[]
  rosterTemplates       RosterTemplate[]
  safetyIssues          SafetyIssue[]
  sessions              Session[]
  users                 User[]
  venues                Venue[]
  zones                 Zone[]

  @@index([status])
  @@index([domain])
}

model ClubDomain {
  id                String   @id @default(cuid())
  clubId            String
  domain            String
  verified          Boolean  @default(false)
  verificationToken String?  @unique
  createdAt         DateTime @default(now())
  club              Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, domain])
  @@index([clubId])
}

model Venue {
  id                   String               @id @default(cuid())
  clubId               String
  name                 String
  slug                 String
  address              String?
  city                 String?
  state                String?
  postalCode           String?
  phone                String?
  timezone             String               @default("Australia/Sydney")
  isDefault            Boolean              @default(false)
  active               Boolean              @default(true)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  publicId             String?              @unique
  classSessions        ClassSession[]
  classTemplates       ClassTemplate[]
  complianceCategories ComplianceCategory[]
  complianceItems      ComplianceItem[]
  equipment            Equipment[]
  equipmentUsage       EquipmentUsage[]
  injuryFormTemplates  InjuryFormTemplate[]
  injurySubmissions    InjurySubmission[]
  maintenanceLogs      MaintenanceLog[]
  maintenanceTasks     MaintenanceTask[]
  repairQuoteRequests  RepairQuoteRequest[]
  rosters              Roster[]
  rosterSlots          RosterSlot[]
  rosterTemplates      RosterTemplate[]
  safetyIssues         SafetyIssue[]
  club                 Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  zones                Zone[]

  @@unique([clubId, slug])
  @@index([clubId])
  @@index([active])
}

model User {
  id                        String                    @id @default(cuid())
  clubId                    String
  email                     String
  username                  String
  passwordHash              String
  fullName                  String
  role                      String                    @default("ADMIN")
  isActive                  Boolean                   @default(true)
  lastLogin                 DateTime?
  loginAttempts             Int                       @default(0)
  lockedUntil               DateTime?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  auditLogs                 AuditLog[]
  generatedSessions         ClassSession[]            @relation("SessionGeneratedBy")
  completedComplianceItems  ComplianceItem[]          @relation("ComplianceItemCompletedBy")
  createdComplianceItems    ComplianceItem[]          @relation("ComplianceItemCreatedBy")
  ownedComplianceItems      ComplianceItem[]          @relation("ComplianceItemOwner")
  emailVerifications        EmailVerification[]
  injuryNotifications       InjuryNotification[]
  assignedInjurySubmissions InjurySubmission[]        @relation("AssignedInjurySubmissions")
  injurySubmissionAudits    InjurySubmissionAudit[]
  injurySubmissionComments  InjurySubmissionComment[]
  passwordResets            PasswordReset[]
  repairQuoteRequests       RepairQuoteRequest[]
  generatedRosters          Roster[]                  @relation("RosterGeneratedBy")
  createdRosterTemplates    RosterTemplate[]          @relation("RosterTemplateCreatedBy")
  sessions                  Session[]
  club                      Club                      @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, username])
  @@unique([clubId, email])
  @@index([clubId])
  @@index([email])
}

model ComplianceCategory {
  id          String           @id @default(cuid())
  clubId      String
  name        String
  description String?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  venueId     String?
  club        Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  venue       Venue?           @relation(fields: [venueId], references: [id], onDelete: Cascade)
  items       ComplianceItem[]

  @@unique([clubId, name])
  @@index([clubId])
  @@index([venueId])
  @@index([isActive])
}

model ComplianceItem {
  id                String              @id @default(cuid())
  clubId            String
  categoryId        String?
  ownerId           String?
  createdById       String?
  completedById     String?
  title             String
  description       String?
  deadlineDate      DateTime
  status            String              @default("OPEN")
  reminderSchedule  String?
  nextReminderDate  DateTime?
  lastReminderSent  DateTime?
  remindersSent     String?
  fileLinks         String?
  notes             String?
  completedAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  ownerName         String?
  ownerEmail        String?
  recurringSchedule String              @default("NONE")
  venueId           String?
  parentItemId      String?
  isTemplate        Boolean             @default(false)
  instanceNumber    Int?
  category          ComplianceCategory? @relation(fields: [categoryId], references: [id])
  club              Club                @relation(fields: [clubId], references: [id], onDelete: Cascade)
  completedBy       User?               @relation("ComplianceItemCompletedBy", fields: [completedById], references: [id])
  createdBy         User?               @relation("ComplianceItemCreatedBy", fields: [createdById], references: [id])
  owner             User?               @relation("ComplianceItemOwner", fields: [ownerId], references: [id])
  venue             Venue?              @relation(fields: [venueId], references: [id], onDelete: Cascade)
  parentItem        ComplianceItem?     @relation("RecurringInstances", fields: [parentItemId], references: [id], onDelete: Cascade)
  instances         ComplianceItem[]    @relation("RecurringInstances")

  @@index([clubId])
  @@index([venueId])
  @@index([categoryId])
  @@index([ownerId])
  @@index([status])
  @@index([deadlineDate])
  @@index([nextReminderDate])
  @@index([parentItemId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  clubId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  club         Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clubId])
  @@index([expiresAt])
}

model EmailVerification {
  id         String    @id @default(cuid())
  userId     String
  clubId     String
  email      String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  club       Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clubId])
  @@index([expiresAt])
}

model PasswordReset {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Service {
  id           String        @id @default(cuid())
  key          String        @unique
  name         String
  description  String?
  icon         String?
  createdAt    DateTime      @default(now())
  clubServices ClubService[]
}

model ClubService {
  id        String   @id @default(cuid())
  clubId    String
  serviceId String
  enabled   Boolean  @default(true)
  plan      String   @default("basic")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([clubId, serviceId])
  @@index([clubId])
  @@index([serviceId])
}

model AuditLog {
  id         String   @id @default(cuid())
  clubId     String
  userId     String?
  action     String
  entityType String
  entityId   String?
  changes    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  club       Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([clubId])
  @@index([userId])
  @@index([createdAt])
}

model Zone {
  id                String                @id @default(cuid())
  clubId            String
  name              String
  description       String?
  allowOverlap      Boolean               @default(false)
  active            Boolean               @default(true)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  isFirst           Boolean               @default(false)
  publicId          String?               @unique
  venueId           String?
  equipment         Equipment[]
  injurySubmissions InjurySubmission[]
  rosterSlots       RosterSlot[]
  sessionsAllowed   SessionAllowedZone[]
  templatesAllowed  TemplateAllowedZone[]
  club              Club                  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  venue             Venue?                @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([clubId, name])
  @@index([clubId])
  @@index([venueId])
}

model Gymsport {
  id             String          @id @default(cuid())
  clubId         String
  name           String
  isPredefined   Boolean         @default(false)
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  classTemplates ClassTemplate[]
  coachGymsports CoachGymsport[]
  club           Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, name])
  @@index([clubId])
}

model Coach {
  id                 String              @id @default(cuid())
  clubId             String
  name               String
  accreditationLevel String?
  membershipNumber   String?
  email              String?
  phone              String?
  importedFromCsv    Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  active             Boolean             @default(true)
  club               Club                @relation(fields: [clubId], references: [id], onDelete: Cascade)
  availability       CoachAvailability[]
  gymsports          CoachGymsport[]
  equipmentUsage     EquipmentUsage[]
  sessionLinks       SessionCoach[]
  templateLinks      TemplateCoach[]

  @@unique([clubId, email])
  @@index([clubId])
}

model CoachGymsport {
  id         String   @id @default(cuid())
  coachId    String
  gymsportId String
  createdAt  DateTime @default(now())
  coach      Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  gymsport   Gymsport @relation(fields: [gymsportId], references: [id], onDelete: Cascade)

  @@unique([coachId, gymsportId])
  @@index([coachId])
  @@index([gymsportId])
}

model CoachAvailability {
  id             String   @id @default(cuid())
  coachId        String
  dayOfWeek      String
  startTimeLocal String
  endTimeLocal   String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  coach          Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@index([coachId])
  @@index([dayOfWeek])
}

model ClassTemplate {
  id                     String                @id @default(cuid())
  clubId                 String
  name                   String
  gymsportId             String?
  level                  String
  lengthMinutes          Int
  defaultRotationMinutes Int
  allowOverlap           Boolean               @default(false)
  activeDays             String
  startTimeLocal         String
  endTimeLocal           String
  notes                  String?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  color                  String?
  venueId                String?
  sessions               ClassSession[]
  club                   Club                  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  gymsport               Gymsport?             @relation(fields: [gymsportId], references: [id])
  venue                  Venue?                @relation(fields: [venueId], references: [id], onDelete: Cascade)
  allowedZones           TemplateAllowedZone[]
  defaultCoaches         TemplateCoach[]

  @@unique([clubId, name])
  @@index([clubId])
  @@index([venueId])
  @@index([gymsportId])
}

model TemplateAllowedZone {
  id         String        @id @default(cuid())
  templateId String
  zoneId     String
  template   ClassTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  zone       Zone          @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([templateId, zoneId])
}

model TemplateCoach {
  id         String        @id @default(cuid())
  templateId String
  coachId    String
  coach      Coach         @relation(fields: [coachId], references: [id], onDelete: Cascade)
  template   ClassTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, coachId])
}

model ClassSession {
  id                   String               @id @default(cuid())
  clubId               String
  templateId           String?
  date                 DateTime
  startTimeLocal       String
  endTimeLocal         String
  rotationMinutes      Int
  allowOverlap         Boolean              @default(false)
  assignedZoneSequence String
  status               String               @default("DRAFT")
  conflictFlag         Boolean              @default(false)
  generatedById        String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  venueId              String?
  club                 Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  generatedBy          User?                @relation("SessionGeneratedBy", fields: [generatedById], references: [id])
  template             ClassTemplate?       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  venue                Venue?               @relation(fields: [venueId], references: [id], onDelete: Cascade)
  equipmentUsage       EquipmentUsage[]
  rosterSlots          RosterSlot[]
  allowedZones         SessionAllowedZone[]
  coaches              SessionCoach[]

  @@index([clubId])
  @@index([venueId])
  @@index([templateId])
  @@index([date])
}

model SessionAllowedZone {
  id        String       @id @default(cuid())
  sessionId String
  zoneId    String
  session   ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  zone      Zone         @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([sessionId, zoneId])
}

model SessionCoach {
  id        String       @id @default(cuid())
  sessionId String
  coachId   String
  coach     Coach        @relation(fields: [coachId], references: [id], onDelete: Cascade)
  session   ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, coachId])
}

model RosterTemplate {
  id          String   @id @default(cuid())
  clubId      String
  name        String
  startDate   DateTime
  endDate     DateTime
  activeDays  String
  classConfig String
  status      String   @default("ACTIVE")
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  venueId     String?
  rosters     Roster[]
  club        Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  createdBy   User?    @relation("RosterTemplateCreatedBy", fields: [createdById], references: [id])
  venue       Venue?   @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([venueId])
  @@index([status])
}

model Roster {
  id            String          @id @default(cuid())
  clubId        String
  templateId    String?
  scope         String
  dayOfWeek     String?
  startDate     DateTime
  endDate       DateTime
  status        String          @default("DRAFT")
  generatedAt   DateTime?
  generatedById String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  venueId       String?
  club          Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  generatedBy   User?           @relation("RosterGeneratedBy", fields: [generatedById], references: [id])
  template      RosterTemplate? @relation(fields: [templateId], references: [id], onDelete: Cascade)
  venue         Venue?          @relation(fields: [venueId], references: [id], onDelete: Cascade)
  slots         RosterSlot[]

  @@index([clubId])
  @@index([venueId])
  @@index([scope])
  @@index([startDate])
  @@index([clubId, startDate, endDate])
}

model RosterSlot {
  id           String       @id @default(cuid())
  clubId       String
  rosterId     String
  sessionId    String
  zoneId       String
  startsAt     DateTime
  endsAt       DateTime
  conflictFlag Boolean      @default(false)
  allowOverlap Boolean      @default(false)
  createdAt    DateTime     @default(now())
  zoneOrder    Int?
  conflictType String?
  venueId      String?
  club         Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  roster       Roster       @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  session      ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  venue        Venue?       @relation(fields: [venueId], references: [id], onDelete: Cascade)
  zone         Zone         @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([venueId])
  @@index([rosterId])
  @@index([sessionId])
  @@index([zoneId])
  @@index([startsAt])
}

model CoachImportJob {
  id           String   @id @default(cuid())
  clubId       String
  status       String   @default("PENDING")
  totalRows    Int?
  importedRows Int?
  errorText    String?
  createdAt    DateTime @default(now())
  club         Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([status])
}

model RosterExport {
  id           String   @id @default(cuid())
  clubId       String
  exportType   String
  status       String   @default("PENDING")
  targetEmails String?
  createdAt    DateTime @default(now())
  club         Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([status])
}

model InjuryFormTemplate {
  id              String                 @id @default(cuid())
  clubId          String
  name            String
  description     String?
  isDefault       Boolean                @default(false)
  active          Boolean                @default(true)
  qrCode          String?
  publicUrl       String                 @unique
  headerColor     String?                @default("#0078d4")
  logoUrl         String?
  thankYouMessage String?                @default("Thank you for your submission. We will review this report shortly.")
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  venueId         String?
  automations     InjuryFormAutomation[]
  fields          InjuryFormField[]
  sections        InjuryFormSection[]
  club            Club                   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  venue           Venue?                 @relation(fields: [venueId], references: [id], onDelete: Cascade)
  submissions     InjurySubmission[]

  @@index([clubId])
  @@index([venueId])
  @@index([active])
  @@index([publicUrl])
}

model InjuryFormSection {
  id          String             @id @default(cuid())
  templateId  String
  title       String
  description String?
  order       Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  fields      InjuryFormField[]
  template    InjuryFormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([order])
}

model InjuryFormField {
  id               String                 @id @default(cuid())
  templateId       String
  sectionId        String?
  fieldType        String
  label            String
  description      String?
  placeholder      String?
  required         Boolean                @default(false)
  order            Int                    @default(0)
  options          String?
  validation       String?
  conditionalLogic String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  section          InjuryFormSection?     @relation(fields: [sectionId], references: [id])
  template         InjuryFormTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  submissionData   InjurySubmissionData[]

  @@index([templateId])
  @@index([sectionId])
  @@index([order])
}

model InjurySubmission {
  id                           String                    @id @default(cuid())
  templateId                   String
  clubId                       String
  submitterInfo                String?
  status                       String                    @default("NEW")
  priority                     String?
  assignedToUserId             String?
  assignedAt                   DateTime?
  resolvedAt                   DateTime?
  retentionDate                DateTime?
  archived                     Boolean                   @default(false)
  submittedAt                  DateTime                  @default(now())
  updatedAt                    DateTime                  @updatedAt
  venueId                      String?
  templateName                 String?
  zoneId                       String?
  equipmentId                  String?
  equipmentMaintenanceSnapshot String?
  equipmentSafetySnapshot      String?
  notifications                InjuryNotification[]
  assignedTo                   User?                     @relation("AssignedInjurySubmissions", fields: [assignedToUserId], references: [id])
  club                         Club                      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  equipment                    Equipment?                @relation(fields: [equipmentId], references: [id])
  template                     InjuryFormTemplate        @relation(fields: [templateId], references: [id], onDelete: Cascade)
  venue                        Venue?                    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  zone                         Zone?                     @relation(fields: [zoneId], references: [id])
  auditLog                     InjurySubmissionAudit[]
  comments                     InjurySubmissionComment[]
  data                         InjurySubmissionData[]

  @@index([clubId])
  @@index([venueId])
  @@index([zoneId])
  @@index([equipmentId])
  @@index([templateId])
  @@index([status])
  @@index([assignedToUserId])
  @@index([submittedAt])
  @@index([retentionDate])
}

model InjurySubmissionData {
  id           String           @id @default(cuid())
  submissionId String
  fieldId      String
  value        String
  createdAt    DateTime         @default(now())
  field        InjuryFormField  @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  submission   InjurySubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([fieldId])
}

model InjurySubmissionComment {
  id           String           @id @default(cuid())
  submissionId String
  userId       String
  comment      String
  isInternal   Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  submission   InjurySubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([userId])
  @@index([createdAt])
}

model InjurySubmissionAudit {
  id           String           @id @default(cuid())
  submissionId String
  userId       String?
  action       String
  oldValue     String?
  newValue     String?
  metadata     String?
  createdAt    DateTime         @default(now())
  submission   InjurySubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  user         User?            @relation(fields: [userId], references: [id])

  @@index([submissionId])
  @@index([userId])
  @@index([createdAt])
}

model InjuryFormAutomation {
  id                String             @id @default(cuid())
  templateId        String
  name              String
  description       String?
  active            Boolean            @default(true)
  order             Int                @default(0)
  triggerConditions String
  actions           String
  emailRecipients   String?
  emailSubject      String?
  emailTemplate     String?
  escalationEnabled Boolean            @default(false)
  escalationHours   Int?
  escalationActions String?
  lastExecuted      DateTime?
  executionCount    Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  template          InjuryFormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([active])
  @@index([order])
}

model InjuryNotification {
  id           String            @id @default(cuid())
  clubId       String
  userId       String
  submissionId String?
  type         String
  title        String
  message      String
  priority     String            @default("NORMAL")
  read         Boolean           @default(false)
  readAt       DateTime?
  actionUrl    String?
  createdAt    DateTime          @default(now())
  club         Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  submission   InjurySubmission? @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model EquipmentCategory {
  id        String   @id @default(cuid())
  clubId    String
  name      String
  isDefault Boolean  @default(false)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, name])
  @@index([clubId])
  @@index([active])
}

model Equipment {
  id                  String               @id @default(cuid())
  clubId              String
  name                String
  category            String?
  active              Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  serialNumber        String?              @unique
  purchaseDate        DateTime?
  purchaseCost        String?
  condition           String?              @default("Good")
  location            String?
  zoneId              String?
  lastMaintenance     DateTime?
  nextMaintenance     DateTime?
  maintenanceNotes    String?
  inUse               Boolean?             @default(false)
  currentClass        String?
  photoUrl            String?
  venueId             String?
  lastCheckedDate     DateTime?
  lastCheckStatus     String?
  lastCheckedBy       String?
  installationDate    DateTime?
  supplier            String?
  invoiceRef          String?
  invoiceFileUrl      String?
  warrantyExpiryDate  DateTime?
  endOfLifeDate       DateTime?
  club                Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  venue               Venue?               @relation(fields: [venueId], references: [id], onDelete: Cascade)
  zone                Zone?                @relation(fields: [zoneId], references: [id])
  usageHistory        EquipmentUsage[]
  injurySubmissions   InjurySubmission[]
  maintenanceLogs     MaintenanceLog[]
  maintenanceTasks    MaintenanceTask[]
  repairQuoteRequests RepairQuoteRequest[]
  safetyIssues        SafetyIssue[]

  @@index([clubId])
  @@index([venueId])
  @@index([active])
  @@index([category])
  @@index([condition])
  @@index([zoneId])
}

model MaintenanceLog {
  id              String    @id @default(cuid())
  clubId          String
  equipmentId     String
  maintenanceType String
  description     String
  performedBy     String?
  cost            String?
  performedAt     DateTime  @default(now())
  createdAt       DateTime  @default(now())
  venueId         String?
  club            Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  equipment       Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  venue           Venue?    @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([venueId])
  @@index([equipmentId])
  @@index([performedAt])
}

model EquipmentUsage {
  id          String        @id @default(cuid())
  clubId      String
  equipmentId String
  sessionId   String?
  coachId     String?
  usedFrom    DateTime
  usedUntil   DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  venueId     String?
  club        Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  coach       Coach?        @relation(fields: [coachId], references: [id])
  equipment   Equipment     @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  session     ClassSession? @relation(fields: [sessionId], references: [id])
  venue       Venue?        @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([venueId])
  @@index([equipmentId])
  @@index([sessionId])
  @@index([usedFrom])
}

model SafetyIssue {
  id                  String               @id @default(cuid())
  clubId              String
  equipmentId         String
  issueType           String
  title               String
  description         String
  reportedBy          String
  reportedByEmail     String?
  photos              String?
  priority            String               @default("MEDIUM")
  status              String               @default("OPEN")
  resolvedAt          DateTime?
  resolvedBy          String?
  resolutionNotes     String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  venueId             String?
  repairQuoteRequests RepairQuoteRequest[]
  club                Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  equipment           Equipment            @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  venue               Venue?               @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([venueId])
  @@index([equipmentId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

model MaintenanceTask {
  id                  String    @id @default(cuid())
  clubId              String
  equipmentId         String
  taskType            String
  title               String
  description         String
  scheduledDate       DateTime?
  dueDate             DateTime?
  completedDate       DateTime?
  assignedTo          String?
  completedBy         String?
  priority            String    @default("MEDIUM")
  status              String    @default("PENDING")
  notes               String?
  photos              String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  cost                String?
  assignedToName      String?
  assignedToEmail     String?
  isRecurring         Boolean   @default(false)
  recurrencePattern   String?
  recurrenceInterval  Int?
  recurrenceDay       Int?
  recurrenceDayOfWeek String?
  recurrenceEndDate   DateTime?
  parentTaskId        String?
  reminderDays        String?
  lastReminderSent    DateTime?
  nextReminderDate    DateTime?
  remindersSent       String?
  venueId             String?
  club                Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  equipment           Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  venue               Venue?    @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([venueId])
  @@index([equipmentId])
  @@index([status])
  @@index([dueDate])
  @@index([isRecurring])
  @@index([nextReminderDate])
  @@index([assignedToEmail])
  @@index([priority])
}

model RepairQuoteRequest {
  id                  String       @id @default(cuid())
  clubId              String
  equipmentId         String
  safetyIssueId       String?
  requestedById       String
  issueDescription    String
  urgency             String       @default("MEDIUM")
  preferredRepairDate DateTime?
  estimatedBudget     String?
  contactPerson       String
  contactPhone        String?
  contactEmail        String?
  additionalNotes     String?
  specialRequirements String?
  photos              String?
  status              String       @default("PENDING")
  emailSent           Boolean      @default(false)
  emailSentAt         DateTime?
  quoteAmount         String?
  quoteReceivedAt     DateTime?
  quoteReceivedFrom   String?
  quoteNotes          String?
  repairCompletedAt   DateTime?
  repairCompletedBy   String?
  finalCost           String?
  completionNotes     String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  quoteDocuments      String?
  approvedBy          String?
  approvedByName      String?
  approvedAt          DateTime?
  approvalNotes       String?
  rejectedBy          String?
  rejectedByName      String?
  rejectedAt          DateTime?
  rejectionReason     String?
  scheduledRepairDate DateTime?
  repairCompanyName   String?
  repairContactPerson String?
  repairContactPhone  String?
  repairContactEmail  String?
  invoiceDocuments    String?
  warrantyInfo        String?
  venueId             String?
  club                Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  equipment           Equipment    @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  requestedBy         User         @relation(fields: [requestedById], references: [id], onDelete: Cascade)
  safetyIssue         SafetyIssue? @relation(fields: [safetyIssueId], references: [id])
  venue               Venue?       @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([venueId])
  @@index([equipmentId])
  @@index([safetyIssueId])
  @@index([requestedById])
  @@index([status])
  @@index([urgency])
  @@index([createdAt])
  @@index([approvedAt])
  @@index([approvedBy])
  @@index([scheduledRepairDate])
}
